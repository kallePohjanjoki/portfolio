---
import Layout from '../layouts/Layout.astro';

// Edit these arrays to update the site — no need to touch the markup below.

const skills = [
  { name: 'Azure', learning: false },
  { name: 'AWS', learning: false },
  { name: 'Terraform', learning: false },
  { name: 'Kubernetes', learning: false },
  { name: 'Docker', learning: false },
  { name: 'Linux', learning: false },
  { name: 'GitHub Actions', learning: false },
  { name: 'Agentic AI', learning: false },
];

const experience = [
  {
    name: 'Lingons',
    role: 'Co-founder',
    period: '04/2026 — present',
    description:
      'Hands-free, audio-first language learning app. Co-founder responsible for cloud infrastructure, backend, and DevOps.',
    stack: 'GCP, Firebase, Go',

  },
  {
    name: 'Lauta Media Ltd.',
    role: 'Software Engineer Intern',
    period: '10/2022 — 12/2022',
    description:
      'Worked on frontend and backend features for one of the top visited websites in Finland.',
    stack: 'PHP, JavaScript, Git, GitHub, Vagrant, MySQL',

  },
  {
    name: 'FDR Ab',
    role: 'Software Engineer Intern',
    period: '10/2021 — 12/2021',
    description:
      'Worked on website development.',
    stack: 'JavaScript, HTML, CSS',

  },
  {
    name: 'Rajala Pro Shop',
    role: 'Customer Support Intern',
    period: '1/2021 — 3/2021',
    description:
      'Worked in customer support, answering emails and packed products.',
    stack: 'Customer Support, Microsoft Office',

  },
];

const projects = [

  {
    name: 'Pohjanjoki.com',
    description:
      'Developed and deployed a portfolio by defining Azure infrastructure as code with Terraform. Established a fully automated GitHub Actions CI/CD pipeline and integrated custom DNS records for domain management.',
    stack: 'Azure, Terraform, GitHub Actions, Astro',
    href: 'https://github.com/kallePohjanjoki/portfolio',
  }
];

const education = [
  {
    institution: 'Tampere University',
    degree: 'Bachelor of Science in Computer Science',
    period: 'Exp. 2028 ',
    description: 'Minor in Business',
  },
  {
    institution: 'Turku University of Applied Sciences',
    degree: 'Bachelor of Business Administration, Business Information Technology',
    period: '2024 — 2026',
    description: 'Not graduated, switched to Computer Science in a university. Specialization in Software Engineering.',
  },
  {
    institution: 'Turku Vocational Institute',
    degree: 'Vocational Qualification in Information and Communications Technology',
    period: '08/2020 — 05/2023',
    description: 'Specialization in Software Engineering.',
  },
  {
    institution: 'Turku Evening High School',
    degree: 'Matriculation Examination',
    period: '08/2020 — 06/2023',
    description: '',
  },
];

const certs = [
  { name: 'AZ-104', issuer: 'Azure Administrator Associate' },
  { name: 'AZ-900', issuer: 'Azure Fundamentals' },
];

const contactLinks = [
  { label: 'Email', href: 'mailto:kalle@pohjanjoki.com' },
  { label: 'GitHub', href: 'https://github.com/kallePohjanjoki' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/kalle-pohjanjoki/' },
];
---

<Layout>
  <header>
    <div class="wrap">
      <div class="logo">Kalle Pohjanjoki</div>
      <nav id="navMenu">
        <a href="#experience">experience</a>
        <a href="#projects">projects</a>
        <a href="#education">education</a>
        <a href="#certifications">certifications</a>
        <a href="#contact">contact</a>
      </nav>
      <div class="header-right">
        <button id="themeToggle" class="theme-toggle" aria-label="Toggle theme">
          <svg class="sun" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"></line><line x1="12" y1="21" x2="12" y2="23"></line><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line x1="1" y1="12" x2="3" y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg>
          <svg class="moon" viewBox="0 0 24 24" width="16" height="16" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg>
        </button>
        <button class="menu-toggle" id="menuToggle" aria-label="Toggle Menu" aria-expanded="false">
          <span class="bar"></span>
          <span class="bar"></span>
          <span class="bar"></span>
        </button>
      </div>
    </div>
  </header>

  <section class="hero">
    <div class="wrap">
      <div class="hero-grid">
        <div class="hero-content">
          <div class="eyebrow">Tampere, Finland</div>
          <h1>Cloud Engineer</h1>
          <h1>CS Student</h1>
          <p>
            Computer Science student at Tampere University. Co-founder handling Cloud
            infrastructure and Backend development at Lingons. Currently studying for the AWS Certified Solutions Architect – Associate certification to complement my Azure background.
          </p>
          <div class="links">
            <a class="btn primary" href="#experience">View experience</a>
            <a class="btn ghost" href="#contact">Get in touch</a>
          </div>
        </div>
        <div class="hero-avatar">
          <img src="/headshot_bw.jpg" alt="Kalle Pohjanjoki" />
        </div>
      </div>
    </div>
  </section>

  <section class="status">
    <div class="wrap">
      <div class="label">// top skills</div>
      <div class="status-grid">
        {skills.map((skill) => (
          <div class="status-item">
            <span class={`dot ${skill.learning ? 'learning' : ''}`}></span>
            {skill.name}
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="block" id="experience">
    <div class="wrap">
      <div class="block-head">
        <h2>Relevant Experience</h2>
        <div class="count">{String(experience.length).padStart(2, '0')}</div>
      </div>

      {experience.map((item) => (
        <div class="project">
          <div class="project-top">
            <h3>{item.name}</h3>
            <span class="tag">{item.period}</span>
          </div>
          {item.role && <div class="role">{item.role}</div>}
          <p>{item.description}</p>
          <div class="stack"><span>Stack —</span> {item.stack}</div>
        </div>
      ))}
    </div>
  </section>

  <section class="block" id="projects">
    <div class="wrap">
      <div class="block-head">
        <h2>Projects</h2>
        <div class="count">{String(projects.length).padStart(2, '0')}</div>
      </div>

      {projects.map((project) => (
        <div class="project">
          <div class="project-top">
            <h3>{project.name}</h3>
            {project.period && <span class="tag">{project.period}</span>}
          </div>
          <p>{project.description}</p>
          <div class="stack"><span>Stack —</span> {project.stack}</div>
          <a class="view" href={project.href}>View project →</a>
        </div>
      ))}
    </div>
  </section>

  <section class="block" id="education">
    <div class="wrap">
      <div class="block-head">
        <h2>Education</h2>
        <div class="count">{String(education.length).padStart(2, '0')}</div>
      </div>

      {education.map((edu) => (
        <div class="project">
          <div class="project-top">
            <h3>{edu.institution}</h3>
            <span class="tag">{edu.period}</span>
          </div>
          <div class="role">{edu.degree}</div>
          {edu.description && <p>{edu.description}</p>}
        </div>
      ))}
    </div>
  </section>

  <section class="block" id="certifications">
    <div class="wrap">
      <div class="block-head">
        <h2>Certifications</h2>
        <div class="count">{String(certs.length).padStart(2, '0')}</div>
      </div>
      <div class="certs">
        {certs.map((cert) => (
          <div class="cert">
            <div class="name">{cert.name}</div>
            <div class="issuer">{cert.issuer}</div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="contact" id="contact">
    <div class="wrap">
      <h2>Open to cloud engineering internships for 2027.</h2>
      <div class="links">
        {contactLinks.map((link) => (
          <a href={link.href} target={link.href.startsWith('http') ? '_blank' : undefined}>
            → {link.label}
          </a>
        ))}
      </div>
    </div>
  </section>

  <footer>
    <div class="wrap" style="display:flex; justify-content:space-between; width:100%;">
      <span>© 2026 Kalle Pohjanjoki</span>
      <span>Built with Astro · deployed to Azure</span>
    </div>
  </footer>

  <script>
    const menuToggle = document.getElementById('menuToggle');
    const navMenu = document.getElementById('navMenu');
    const navLinks = navMenu?.querySelectorAll('a');
    const themeToggle = document.getElementById('themeToggle');

    // Theme Toggle Handler
    themeToggle?.addEventListener('click', () => {
      const isDark = document.documentElement.getAttribute('data-theme') === 'dark';
      if (isDark) {
        document.documentElement.removeAttribute('data-theme');
        localStorage.setItem('theme', 'light');
      } else {
        document.documentElement.setAttribute('data-theme', 'dark');
        localStorage.setItem('theme', 'dark');
      }
    });

    // Listen for system theme changes in real-time
    window.matchMedia('(prefers-color-scheme: dark)').addEventListener('change', (e) => {
      if (typeof localStorage !== 'undefined' && !localStorage.getItem('theme')) {
        if (e.matches) {
          document.documentElement.setAttribute('data-theme', 'dark');
        } else {
          document.documentElement.removeAttribute('data-theme');
        }
      }
    });

    // Mobile Hamburger Handler
    if (menuToggle && navMenu) {
      menuToggle.addEventListener('click', (e) => {
        e.stopPropagation();
        const isExpanded = menuToggle.getAttribute('aria-expanded') === 'true';
        menuToggle.setAttribute('aria-expanded', String(!isExpanded));
        menuToggle.classList.toggle('active');
        navMenu.classList.toggle('active');
      });

      navLinks?.forEach(link => {
        link.addEventListener('click', () => {
          menuToggle.setAttribute('aria-expanded', 'false');
          menuToggle.classList.remove('active');
          navMenu.classList.remove('active');
        });
      });

      document.addEventListener('click', (event) => {
        const target = event.target as HTMLElement;
        const isClickInside = menuToggle.contains(target) || navMenu.contains(target) || (themeToggle && themeToggle.contains(target));
        if (!isClickInside && navMenu.classList.contains('active')) {
          menuToggle.setAttribute('aria-expanded', 'false');
          menuToggle.classList.remove('active');
          navMenu.classList.remove('active');
        }
      });
    }
  </script>
</Layout>
